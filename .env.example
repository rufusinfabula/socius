# ============================================================
# SOCIUS — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Socius"
APP_ENV=production          # local | production
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Europe/Rome
APP_LOCALE=it               # it | en

# Secret key used for signing tokens/sessions (generate a random 64-char string)
APP_KEY=

# ------------------------------------------------------------
# Database (MySQL / MariaDB)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=socius
DB_USERNAME=socius_user
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=

# ------------------------------------------------------------
# Session
# ------------------------------------------------------------
SESSION_DRIVER=file         # file | database
SESSION_LIFETIME=120        # minutes
SESSION_SECURE_COOKIE=true

# ------------------------------------------------------------
# Mail / SMTP
# ------------------------------------------------------------
MAIL_DRIVER=smtp            # smtp | sendmail | log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls         # tls | ssl | null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------
# PayPal
# ------------------------------------------------------------
PAYPAL_MODE=sandbox         # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CURRENCY=EUR
PAYPAL_WEBHOOK_ID=

# ------------------------------------------------------------
# Satispay
# ------------------------------------------------------------
SATISPAY_ENVIRONMENT=staging  # staging | production
SATISPAY_KEY_ID=
SATISPAY_PRIVATE_KEY_PATH=storage/keys/satispay_private.pem
SATISPAY_PUBLIC_KEY_PATH=storage/keys/satispay_public.pem
SATISPAY_CURRENCY=EUR
SATISPAY_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------
STORAGE_UPLOADS_MAX_SIZE=10240   # KB (10 MB)
STORAGE_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,gif

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=file            # file | stderr
LOG_LEVEL=warning           # debug | info | warning | error
