Options -Indexes

# =============================================================================
# URL Rewriting — OPTIONAL (clean URLs)
# =============================================================================
# Socius works without this block: use ?route=path query-string routing.
# Enable this block only if mod_rewrite is available and you want clean URLs.
# See README.md § "URL Configuration" for details.
# =============================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Allow direct access to real files and directories (css, js, images…)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through the front controller
    RewriteRule ^ index.php [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|log|sh|sql|bak|cfg|ini)$">
    Require all denied
</FilesMatch>

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 60
</IfModule>
