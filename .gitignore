# Environment
.env

# Composer
/vendor/
composer.lock

# Storage (keep structure, ignore content)
/storage/logs/*.log
/storage/uploads/*
/storage/exports/*
!/storage/logs/.gitkeep
!/storage/uploads/.gitkeep
!/storage/exports/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Install lock file (created after successful installation)
/install/install.lock

# Cache
/storage/cache/*
!/storage/cache/.gitkeep

# Debug / one-time scripts
/public/debug.php
/public/opcache-reset.php
